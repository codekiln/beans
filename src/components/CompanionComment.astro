---
/**
 * Inline companion comment: terminal-native quoted aside with optional portrait.
 * Usage: <CompanionComment from="unicorn">bed of crystalline flowers</CompanionComment>
 * Optional: <CompanionComment from="sproglo" variant="bubble">sharp</CompanionComment>
 *
 * Variants: "terminal" (default) | "bubble" | "ascii"
 * - terminal: simple bordered box, quote left, avatar + name right (no extra glyphs)
 * - bubble: rounded speech bubble, larger circular avatar, name below avatar
 * - ascii: comment-syntax pun (slash-star markers), left border, avatar in frame, name below
 *
 * Portrait and name link to companion detail. Decorative borders are aria-hidden.
 */
import { getCompanionBySlug, getCompanionPath, getCompanionPortrait } from "../data/companions";
import { withBase } from "../utils/paths";

interface Props {
  from: string;
  variant?: "terminal" | "bubble" | "ascii";
}

const { from, variant = "terminal" } = Astro.props;
const companion = await getCompanionBySlug(from);
const companionName = companion?.data.name ?? from;
const companionTitle = companion?.data.title;
const companionHref = companion ? withBase(getCompanionPath(companion.slug)) : null;
const portrait = companion ? getCompanionPortrait(companion.data) : null;
const portraitSrc = portrait ? withBase(portrait.src) : null;
const portraitDarkSrc = portrait ? withBase(portrait.darkSrc ?? portrait.src) : null;
---

<aside class={`companion-comment companion-comment--${variant}`} aria-label={`${companionName} says`}>
  {/* Single semantic blockquote: quote text left, companion attribution panel right */}
  <blockquote class="companion-comment__quote">
    {variant === "ascii" ? (
      <div class="companion-comment__ascii-box">
        <div class="companion-comment__ascii-border-row companion-comment__ascii-border-row--top" aria-hidden="true">
          <span class="companion-comment__ascii-corner">+</span>
          <span class="companion-comment__ascii-h"></span>
          <span class="companion-comment__ascii-corner">+</span>
          <span class="companion-comment__ascii-corner-right">+---+</span>
        </div>
        <div class="companion-comment__ascii-content-row">
          <span class="companion-comment__ascii-v" aria-hidden="true">|</span>
          <div class="companion-comment__ascii-body-cell">
            <span class="companion-comment__ascii-comment-open">/*</span>
            <p class="companion-comment__body companion-comment__body--ascii"><slot /></p>
            <span class="companion-comment__ascii-comment-close">*/</span>
          </div>
          <span class="companion-comment__ascii-v" aria-hidden="true">|</span>
          <div class="companion-comment__ascii-portrait-cell">
            {portraitSrc ? (
              <>
                <span class="companion-comment__ascii-frame-edge" aria-hidden="true">+---+</span>
                <div class="companion-comment__portrait-wrap companion-comment__portrait-wrap--ascii">
                  {companionHref ? (
                    <a href={companionHref} class="companion-comment__portrait-link">
                      <img data-companion-portrait="" data-light-src={portraitSrc} data-dark-src={portraitDarkSrc} src={portraitSrc} alt="" loading="lazy" />
                    </a>
                  ) : (
                    <span class="companion-comment__portrait-link">
                      <img data-companion-portrait="" data-light-src={portraitSrc} data-dark-src={portraitDarkSrc} src={portraitSrc} alt="" loading="lazy" />
                    </span>
                  )}
                </div>
                <span class="companion-comment__ascii-frame-edge" aria-hidden="true">+---+</span>
              </>
            ) : (
              <>
                <span class="companion-comment__ascii-frame-edge" aria-hidden="true">+---+</span>
                <span class="companion-comment__ascii-frame-placeholder" aria-hidden="true">|   |</span>
                <span class="companion-comment__ascii-frame-edge" aria-hidden="true">+---+</span>
              </>
            )}
          </div>
          <span class="companion-comment__ascii-v" aria-hidden="true">|</span>
        </div>
        <div class="companion-comment__ascii-border-row companion-comment__ascii-border-row--bottom" aria-hidden="true">
          <span class="companion-comment__ascii-corner">+</span>
          <span class="companion-comment__ascii-h"></span>
          <span class="companion-comment__ascii-corner">+</span>
          <span class="companion-comment__ascii-corner-right">+---+</span>
        </div>
        <span class="companion-comment__name companion-comment__name--ascii">
          {companionHref ? (
            <a href={companionHref}>{companionName}</a>
          ) : (
            companionName
          )}
          {companionTitle && <span class="sr-only">, {companionTitle}</span>}
        </span>
      </div>
    ) : (
      <div class="companion-comment__row">
        <div class="companion-comment__body-zone">
          <p class="companion-comment__body"><slot /></p>
        </div>
        <div class="companion-comment__panel">
          <div class="companion-comment__portrait-wrap">
            {portraitSrc && (companionHref ? (
              <a href={companionHref} class="companion-comment__portrait-link">
                <img data-companion-portrait="" data-light-src={portraitSrc} data-dark-src={portraitDarkSrc} src={portraitSrc} alt="" loading="lazy" />
              </a>
            ) : (
              <span class="companion-comment__portrait-link">
                <img data-companion-portrait="" data-light-src={portraitSrc} data-dark-src={portraitDarkSrc} src={portraitSrc} alt="" loading="lazy" />
              </span>
            ))}
          </div>
          <span class="companion-comment__name">
            {companionHref ? (
              <a href={companionHref}>{companionName}</a>
            ) : (
              companionName
            )}
            {companionTitle && <span class="sr-only">, {companionTitle}</span>}
          </span>
        </div>
      </div>
    )}
  </blockquote>
</aside>

<style>
  /* Shared: compact, content-led, strong contrast */
  .companion-comment {
    margin: 1.25rem 0;
  }

  /* Single blockquote: content-sized, quote left + panel right */
  .companion-comment__quote {
    margin: 0;
    display: inline-flex;
    max-width: 100%;
    position: relative;
  }

  .companion-comment__row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 0.75rem 1rem;
    flex: 1 1 auto;
    min-width: 0;
  }

  .companion-comment__body-zone {
    flex: 1 1 auto;
    min-width: 0;
    position: relative;
  }

  .companion-comment__body {
    margin: 0;
    white-space: pre-line;
    font-style: italic;
    line-height: 1.5;
  }

  .companion-comment__panel {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
  }

  .companion-comment__portrait-wrap {
    display: block;
    line-height: 0;
  }

  .companion-comment__portrait-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .companion-comment__portrait-link img {
    display: block;
    width: 40px;
    height: 40px;
    object-fit: cover;
    image-rendering: pixelated;
    border-radius: 50%;
  }

  .companion-comment__name {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .companion-comment__name a {
    color: inherit;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  .companion-comment__name a:hover {
    text-decoration-thickness: 2px;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ---- Variant: terminal (box-drawing) ---- */
  .companion-comment--terminal .companion-comment__quote {
    padding: 0.5rem 0.75rem 0.5rem 1rem;
    border: 1px solid var(--cc-border, #5a5a5a);
    background: var(--cc-bg, #f5f2ec);
    color: var(--cc-fg, #2a2a2a);
  }

  .companion-comment--terminal .companion-comment__body {
    font-style: italic;
    color: inherit;
  }

  /* Full overlay so corners don't take flow space; corners are absolutely positioned within it */
  /* Suppress global .markdown blockquote::before so companion blockquotes stay clean */
  :global(.markdown) .companion-comment__quote::before {
    content: none;
  }

  .companion-comment--terminal .companion-comment__name {
    color: var(--cc-muted, #555);
  }

  /* ---- Variant: bubble (rounded, circular avatar) ---- */
  .companion-comment--bubble .companion-comment__quote {
    padding: 0.5rem 0.9rem 0.6rem;
    border-radius: 1rem 1rem 1rem 0.1rem;
    background: var(--cc-bg, #f0ede6);
    color: var(--cc-fg, #2a2a2a);
    border: 1px solid var(--cc-border, #b8b4a8);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }

  .companion-comment--bubble .companion-comment__body {
    font-style: italic;
    color: inherit;
  }

  .companion-comment--bubble .companion-comment__portrait-link img {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid var(--cc-border, #b8b4a8);
  }

  .companion-comment--bubble .companion-comment__name {
    color: var(--cc-muted, #555);
  }

  /* ---- Variant: ascii (comment block with ASCII box + rectangular portrait) ---- */
  .companion-comment--ascii .companion-comment__quote {
    display: block;
    padding: 0;
    background: transparent;
    color: var(--cc-fg, #2a2a2a);
    border: none;
  }

  .companion-comment__ascii-box {
    display: inline-block;
    min-width: 18rem;
    max-width: 100%;
    font-family: ui-monospace, monospace;
    font-size: 0.8rem;
    line-height: 1.4;
    color: var(--cc-fg, #2a2a2a);
    background: var(--cc-bg, #f8f6f1);
    vertical-align: top;
  }

  .companion-comment__ascii-border-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: stretch;
    min-height: 1.2em;
  }

  .companion-comment__ascii-corner,
  .companion-comment__ascii-corner-right {
    color: var(--cc-border, #6b6b6b);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .companion-comment__ascii-h {
    flex: 1 1 auto;
    min-width: 3rem;
    min-height: 1px;
    border-bottom: 1px solid var(--cc-border, #6b6b6b);
    margin-bottom: -1px;
  }

  .companion-comment__ascii-border-row--bottom .companion-comment__ascii-h {
    border-bottom: none;
    border-top: 1px solid var(--cc-border, #6b6b6b);
    margin-bottom: 0;
    margin-top: -1px;
  }

  .companion-comment__ascii-content-row {
    display: flex;
    flex-wrap: nowrap;
    align-items: stretch;
  }

  .companion-comment__ascii-v {
    color: var(--cc-border, #6b6b6b);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .companion-comment__ascii-body-cell {
    flex: 1 1 auto;
    min-width: 6rem;
    padding: 0.2rem 0.5rem 0.35rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .companion-comment__ascii-comment-open,
  .companion-comment__ascii-comment-close {
    color: var(--cc-muted, #888);
    font-size: 0.85em;
  }

  .companion-comment--ascii .companion-comment__body--ascii {
    margin: 0;
    padding-left: 0.35rem;
    font-style: italic;
    color: inherit;
    white-space: pre-line;
  }

  .companion-comment__ascii-body-cell .companion-comment__body--ascii::before {
    content: "* ";
    color: var(--cc-muted, #888);
  }

  .companion-comment__ascii-portrait-cell {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0.2rem 0.35rem 0.35rem;
  }

  .companion-comment__ascii-frame-edge {
    display: block;
    font-size: 0.75em;
    line-height: 1;
    color: var(--cc-border, #6b6b6b);
  }

  .companion-comment__ascii-frame-placeholder {
    display: block;
    font-size: 0.75em;
    line-height: 1;
    color: var(--cc-border, #6b6b6b);
  }

  .companion-comment__portrait-wrap--ascii {
    line-height: 0;
  }

  .companion-comment__portrait-wrap--ascii .companion-comment__portrait-link img {
    display: block;
    width: 56px;
    height: 72px;
    object-fit: cover;
    image-rendering: pixelated;
    border-radius: 0;
  }

  .companion-comment__name--ascii {
    display: block;
    text-align: center;
    margin-top: 0.25rem;
    padding-bottom: 0.15rem;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--cc-muted, #555);
  }

  /* Dark theme: neutral grays, no saturated blue */
  :global(:root[data-theme="dark"]) .companion-comment--terminal .companion-comment__quote {
    --cc-border: #6a6a6a;
    --cc-bg: #2a2825;
    --cc-fg: #e8e6e2;
  }

  :global(:root[data-theme="dark"]) .companion-comment--terminal .companion-comment__name {
    --cc-muted: #9a9894;
  }

  :global(:root[data-theme="dark"]) .companion-comment--bubble .companion-comment__quote {
    --cc-border: #4a4844;
    --cc-bg: #2a2825;
    --cc-fg: #e8e6e2;
  }

  :global(:root[data-theme="dark"]) .companion-comment--bubble .companion-comment__portrait-link img {
    border-color: #4a4844;
  }

  :global(:root[data-theme="dark"]) .companion-comment--bubble .companion-comment__name {
    --cc-muted: #9a9894;
  }

  :global(:root[data-theme="dark"]) .companion-comment--ascii .companion-comment__ascii-box {
    --cc-border: #6a6a6a;
    --cc-bg: #2a2825;
    --cc-fg: #e8e6e2;
  }

  :global(:root[data-theme="dark"]) .companion-comment--ascii .companion-comment__ascii-comment-open,
  :global(:root[data-theme="dark"]) .companion-comment--ascii .companion-comment__ascii-comment-close {
    --cc-muted: #7a7874;
  }

  :global(:root[data-theme="dark"]) .companion-comment--ascii .companion-comment__name--ascii {
    --cc-muted: #9a9894;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root[data-theme="auto"]) .companion-comment--terminal .companion-comment__quote {
      --cc-border: #6a6a6a;
      --cc-bg: #2a2825;
      --cc-fg: #e8e6e2;
    }

    :global(:root[data-theme="auto"]) .companion-comment--terminal .companion-comment__name {
      --cc-muted: #9a9894;
    }

    :global(:root[data-theme="auto"]) .companion-comment--bubble .companion-comment__quote {
      --cc-border: #4a4844;
      --cc-bg: #2a2825;
      --cc-fg: #e8e6e2;
    }

    :global(:root[data-theme="auto"]) .companion-comment--bubble .companion-comment__portrait-link img {
      border-color: #4a4844;
    }

    :global(:root[data-theme="auto"]) .companion-comment--bubble .companion-comment__name {
      --cc-muted: #9a9894;
    }

    :global(:root[data-theme="auto"]) .companion-comment--ascii .companion-comment__ascii-box {
      --cc-border: #6a6a6a;
      --cc-bg: #2a2825;
      --cc-fg: #e8e6e2;
    }

    :global(:root[data-theme="auto"]) .companion-comment--ascii .companion-comment__ascii-comment-open,
    :global(:root[data-theme="auto"]) .companion-comment--ascii .companion-comment__ascii-comment-close {
      --cc-muted: #7a7874;
    }

    :global(:root[data-theme="auto"]) .companion-comment--ascii .companion-comment__name--ascii {
      --cc-muted: #9a9894;
    }
  }
</style>
