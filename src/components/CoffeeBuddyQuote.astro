---
import type { CompanionEntry } from "../data/companions";
import { getCompanionPath, getCompanionPortrait } from "../data/companions";
import { withBase } from "../utils/paths";

type BuddyComment = {
  body: string;
};

interface Props {
  comment?: BuddyComment;
  companion?: CompanionEntry | null;
}

const { comment, companion } = Astro.props as Props;
const titleId = `buddy-comment-${Math.random().toString(36).slice(2, 10)}`;
const companionHref = companion ? withBase(getCompanionPath(companion.slug)) : null;
const portrait = companion ? getCompanionPortrait(companion.data) : null;
const companionName = companion?.data.name ?? "Virtual companion";
const companionTitle = companion?.data.title;
---
{comment && (
  <aside class="buddy-quote" aria-labelledby={titleId}>
    <div class="buddy-quote-shell">
      <div class="buddy-portrait-frame" aria-hidden="true">
        {portrait && (
          <img
            data-companion-portrait=""
            data-light-src={withBase(portrait.src)}
            data-dark-src={withBase(portrait.darkSrc ?? portrait.src)}
            src={withBase(portrait.src)}
            alt=""
            loading="lazy"
          />
        )}
      </div>
      <div class="buddy-copy">
        <p class="buddy-kicker">Coffee Buddy Comment</p>
        <p class="buddy-source" id={titleId}>{companionName}</p>
        <blockquote class="buddy-dialogue" aria-label={`${companionName} says`}>
          <p>{comment.body}</p>
          <footer class="buddy-attribution">
            <span aria-hidden="true">--</span>
            {companionHref ? <a href={companionHref}>{companionName}</a> : companionName}
            {companionTitle && <span class="sr-only">, {companionTitle}</span>}
          </footer>
        </blockquote>
      </div>
    </div>
  </aside>
)}

<script is:inline>
  const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");
  const applyCompanionPortrait = () => {
    const theme = document.documentElement.dataset.theme ?? "auto";
    const useDark = theme === "dark" || (theme === "auto" && prefersDark.matches);
    document.querySelectorAll("[data-companion-portrait]").forEach((img) => {
      const lightSrc = img.getAttribute("data-light-src");
      const darkSrc = img.getAttribute("data-dark-src");
      if (!lightSrc || !darkSrc) return;
      const nextSrc = useDark ? darkSrc : lightSrc;
      if (img.getAttribute("src") !== nextSrc) {
        img.setAttribute("src", nextSrc);
      }
    });
  };

  applyCompanionPortrait();
  new MutationObserver(applyCompanionPortrait).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"]
  });
  prefersDark.addEventListener("change", applyCompanionPortrait);
</script>

<style>
  .buddy-quote {
    margin-top: 1.75rem;
    padding: 0.55rem;
    border: 3px solid #22171a;
    background:
      linear-gradient(180deg, #f2ddae 0%, #e5be72 100%);
    box-shadow:
      0 0 0 3px #5c3b22,
      0 0 0 6px #c89448;
  }

  .buddy-quote-shell {
    display: grid;
    grid-template-columns: 108px minmax(0, 1fr);
    gap: 0.85rem;
    align-items: end;
    border: 2px solid #22171a;
    background:
      linear-gradient(180deg, #fffaf0 0%, #f5ead2 100%);
    padding: 0.75rem;
  }

  .buddy-portrait-frame {
    align-self: stretch;
    display: flex;
    align-items: end;
    justify-content: center;
    padding: 0.45rem;
    border: 2px solid #432914;
    background:
      linear-gradient(180deg, #7f5231 0%, #5e3b24 100%);
    box-shadow: inset 0 0 0 2px #d4a160;
  }

  .buddy-portrait-frame img {
    display: block;
    width: 100%;
    max-width: 92px;
    height: auto;
    image-rendering: pixelated;
    filter: drop-shadow(0 2px 0 rgba(24, 15, 12, 0.8));
  }

  .buddy-copy {
    min-width: 0;
  }

  .buddy-kicker {
    margin: 0 0 0.35rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7a5533;
  }

  .buddy-source {
    margin: 0 0 0.45rem;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #7a5533;
  }

  .buddy-dialogue {
    margin: 0;
    padding: 1.1rem 0.9rem 0.8rem;
    border: 2px solid #342018;
    background: #fffdf7;
    color: #2a1d13;
    line-height: 1.56;
    position: relative;
  }

  .buddy-dialogue p {
    margin: 0;
    white-space: pre-line;
    font-family: "Trebuchet MS", "Verdana", sans-serif;
  }

  .buddy-dialogue::before {
    content: "“";
    position: absolute;
    top: 0.2rem;
    left: 0.65rem;
    font-size: 2rem;
    line-height: 1;
    color: #866149;
  }

  .buddy-attribution {
    margin-top: 0.65rem;
    font-size: 0.88rem;
    color: #6b4b36;
  }

  .buddy-attribution a {
    color: inherit;
  }

  :global(:root[data-theme="dark"]) .buddy-quote {
    border-color: #130d0e;
    background: linear-gradient(180deg, #3b2a24 0%, #251a17 100%);
    box-shadow:
      0 0 0 3px #0f0b0c,
      0 0 0 6px #6b4727;
  }

  :global(:root[data-theme="dark"]) .buddy-quote-shell {
    border-color: #a27c4e;
    background: linear-gradient(180deg, #191311 0%, #241a18 100%);
  }

  :global(:root[data-theme="dark"]) .buddy-portrait-frame {
    border-color: #c18b53;
    background: linear-gradient(180deg, #3e2619 0%, #2c1a13 100%);
    box-shadow: inset 0 0 0 2px #8e6439;
  }

  :global(:root[data-theme="dark"]) .buddy-portrait-frame img {
    filter:
      drop-shadow(0 1px 0 rgba(0, 0, 0, 0.55))
      drop-shadow(0 0 8px rgba(177, 105, 48, 0.25));
  }

  :global(:root[data-theme="dark"]) .buddy-kicker {
    color: #be935f;
  }

  :global(:root[data-theme="dark"]) .buddy-source {
    color: #d5aa76;
  }

  :global(:root[data-theme="dark"]) .buddy-dialogue {
    border-color: #9f7746;
    background: #120f0e;
    color: #f4e6cf;
  }

  :global(:root[data-theme="dark"]) .buddy-dialogue::before {
    color: #d0a26c;
  }

  :global(:root[data-theme="dark"]) .buddy-attribution {
    color: #d7b48a;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root[data-theme="auto"]) .buddy-quote {
      border-color: #130d0e;
      background: linear-gradient(180deg, #3b2a24 0%, #251a17 100%);
      box-shadow:
        0 0 0 3px #0f0b0c,
        0 0 0 6px #6b4727;
    }

    :global(:root[data-theme="auto"]) .buddy-quote-shell {
      border-color: #a27c4e;
      background: linear-gradient(180deg, #191311 0%, #241a18 100%);
    }

    :global(:root[data-theme="auto"]) .buddy-portrait-frame {
      border-color: #c18b53;
      background: linear-gradient(180deg, #3e2619 0%, #2c1a13 100%);
      box-shadow: inset 0 0 0 2px #8e6439;
    }

    :global(:root[data-theme="auto"]) .buddy-portrait-frame img {
      filter:
        drop-shadow(0 1px 0 rgba(0, 0, 0, 0.55))
        drop-shadow(0 0 8px rgba(177, 105, 48, 0.25));
    }

    :global(:root[data-theme="auto"]) .buddy-kicker {
      color: #be935f;
    }

    :global(:root[data-theme="auto"]) .buddy-source {
      color: #d5aa76;
    }

    :global(:root[data-theme="auto"]) .buddy-dialogue {
      border-color: #9f7746;
      background: #120f0e;
      color: #f4e6cf;
    }

    :global(:root[data-theme="auto"]) .buddy-dialogue::before {
      color: #d0a26c;
    }

    :global(:root[data-theme="auto"]) .buddy-attribution {
      color: #d7b48a;
    }
  }

  @media (max-width: 640px) {
    .buddy-quote-shell {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .buddy-portrait-frame {
      max-width: 132px;
    }
  }
</style>
