---
import TagRow from "./TagRow.astro";
import CoffeeBuddyQuote from "./CoffeeBuddyQuote.astro";
import { getCompanionBySlug } from "../data/companions";
import { getBeanRouteInfo, getBeans } from "../data/beans";
import { withBase } from "../utils/paths";

const { bean, routeInfo = null, showBuddyComment = false, showClosingMark = false } = Astro.props;
const { Content } = await bean.render();
const beanRouteInfo = routeInfo ?? getBeanRouteInfo(bean, await getBeans());
const companion = bean.data.personaComment
  ? await getCompanionBySlug(bean.data.personaComment.companion)
  : null;
const logCommand = beanRouteInfo.commandText;
const command = `$ bean ${logCommand}`;
const commandLabel = `bean ${logCommand}`;
const detailHref = withBase(beanRouteInfo.path);
const promptTime = bean.data.time
  ? bean.data.time
      .split(":")
      .slice(0, 2)
      .map((part) => part.padStart(2, "0"))
      .join(":")
  : null;

const coffeeRows = [
  bean.data.coffee.roaster && {
    label: "roaster",
    value: bean.data.coffee.roaster.name,
    href: withBase(`/roasters/${bean.data.coffee.roaster.slug}/`)
  },
  bean.data.coffee.roast && {
    label: "coffee",
    value: bean.data.coffee.roast.name,
    href: withBase(`/coffees/${bean.data.coffee.roast.slug}/`)
  },
  bean.data.coffee.roastLevel && { label: "roast level", value: bean.data.coffee.roastLevel },
  bean.data.coffee.profile && { label: "profile", value: bean.data.coffee.profile },
  bean.data.coffee.blend && { label: "blend", value: bean.data.coffee.blend }
].filter(Boolean);

const grindValue = bean.data.brewDetails.grind ?? bean.data.brewDetails.setting;
const brewDetailsRows = [
  bean.data.brew.recipe && {
    label: "recipe",
    value: bean.data.brew.recipe.name,
    href: withBase(`/recipes/${bean.data.brew.recipe.slug}/`)
  },
  bean.data.brewDetails.dose && { label: "dose", value: bean.data.brewDetails.dose },
  grindValue && { label: "grind", value: grindValue },
  bean.data.brewDetails.water && { label: "water", value: bean.data.brewDetails.water },
  bean.data.brewDetails.ratio && { label: "ratio", value: bean.data.brewDetails.ratio },
  bean.data.brewDetails.temp && { label: "temp", value: bean.data.brewDetails.temp },
  bean.data.brewDetails.release && {
    label: "release time",
    value: bean.data.brewDetails.release,
    definition: "Time when the brew valve is opened or the release step begins."
  },
  bean.data.brewDetails.total && {
    label: "total brew time",
    value: bean.data.brewDetails.total,
    definition: "Total time from first pour to the end of drawdown."
  }
].filter(Boolean);

const gearItems = [
  bean.data.brew.brewer && {
    label: "brewer",
    value: bean.data.brew.brewer.name,
    slug: bean.data.brew.brewer.slug,
    href: withBase(`/equipment/${bean.data.brew.brewer.slug}/`)
  },
  bean.data.brewDetails.grinder && {
    label: "grinder",
    value: bean.data.brewDetails.grinder.name,
    slug: bean.data.brewDetails.grinder.slug,
    href: withBase(`/equipment/${bean.data.brewDetails.grinder.slug}/`)
  },
  ...(bean.data.gear ?? []).map((item) => ({
    ...item,
    href:
      item.label.toLowerCase() === "companion" && item.slug
        ? withBase(`/companion/${item.slug}/`)
        : item.slug
          ? withBase(`/equipment/${item.slug}/`)
          : undefined
  }))
].filter(Boolean);
---
<article
  class="bean-entry"
  id={bean.slug}
  data-cli={command}
  data-cli-log={logCommand}
  data-cli-href={detailHref}
>
  <div class="bean-grid">
    <div class="bean-main window">
      <header>
        <h2 class="bean-prompt">
          <a class="bean-prompt-link" href={detailHref}>
            <span class="bean-prompt-time">
              {promptTime && <span>{promptTime}</span>}
              <span class="bean-prompt-emoji" aria-hidden="true">🫘</span>
              <span aria-hidden="true">&gt;</span>
            </span>
            <span class="bean-prompt-command">{commandLabel}</span>
          </a>
        </h2>
        <p class="bean-title">{bean.data.title}</p>
      </header>
      <section class="bean-content markdown">
        {bean.data.image && (
          <figure class="bean-observation-media">
            <img src={withBase(bean.data.image.src)} alt={bean.data.image.alt} loading="lazy" />
          </figure>
        )}
        <Content />
        <TagRow tags={bean.data.tags} />
        {showBuddyComment && (
          <CoffeeBuddyQuote comment={bean.data.personaComment} companion={companion} />
        )}
        {showClosingMark && (
          <p class="bean-closing-mark" aria-hidden="true">
            :wq
          </p>
        )}
      </section>
    </div>
    <aside class="bean-side" aria-label="Bean support panes">
      <section class="window">
        {coffeeRows.length > 0 ? (
          <table class="cup-table">
            <caption>COFFEE</caption>
            <tbody>
              {coffeeRows.map((row) => (
                <tr>
                  <th scope="row">{row.label.toUpperCase()}</th>
                  <td>
                    {row.href ? <a href={row.href}>{row.value}</a> : row.value}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p>No coffee details logged for this cup.</p>
        )}
      </section>
      <section class="window">
        {brewDetailsRows.length > 0 ? (
          <table class="cup-table">
            <caption>BREW DETAILS</caption>
            <tbody>
              {brewDetailsRows.map((row) => (
                <tr>
                  <th scope="row">
                    <span>{row.label.toUpperCase()}</span>
                    {row.definition && (
                      <details>
                        <summary aria-label={`Definition: ${row.label}`}>ⓘ</summary>
                        <p>{row.definition}</p>
                      </details>
                    )}
                  </th>
                  <td>{row.href ? <a href={row.href}>{row.value}</a> : row.value}</td>
                </tr>
              ))}
            </tbody>
          </table>
        ) : (
          <p>No brew details logged for this cup.</p>
        )}
      </section>
      <section class="window">
        <h3 class="section-title">Gear</h3>
        {gearItems.length ? (
          <ul>
            {gearItems.map((item) => (
              <li>
                {item.label}:{" "}
                {item.href ? (
                  <a href={item.href}>{item.value}</a>
                ) : (
                  item.value
                )}
              </li>
            ))}
          </ul>
        ) : (
          <p>No additional gear logged for this cup.</p>
        )}
      </section>
    </aside>
  </div>
</article>
