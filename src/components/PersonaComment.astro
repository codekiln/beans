---
import { withBase } from "../utils/paths";

type PersonaComment = {
  name: string;
  title: string;
  body: string;
};

interface Props {
  comment?: PersonaComment;
}

const { comment } = Astro.props as Props;
---
{comment && (
  <section class="rin-dialogue" aria-label={`${comment.name} commentary`}>
    <div class="rin-dialogue-shell">
      <div class="rin-copy">
        <p class="rin-disclosure">Companion Comment</p>
        <p class="rin-meta">
          <strong>{comment.name}</strong>
          <span>{comment.title}</span>
        </p>
        <p class="rin-body">{comment.body}</p>
      </div>
      <div class="rin-portrait" aria-hidden="true">
        <img
          data-rin-portrait
          data-light-src={withBase("/images/rin-vale-portrait.png")}
          data-dark-src={withBase("/images/rin-vale-portrait-dark.png")}
          src={withBase("/images/rin-vale-portrait.png")}
          alt=""
          loading="lazy"
        />
      </div>
    </div>
  </section>
)}

<script is:inline>
  const prefersDark = window.matchMedia("(prefers-color-scheme: dark)");
  const applyRinPortrait = () => {
    const theme = document.documentElement.dataset.theme ?? "auto";
    const useDark = theme === "dark" || (theme === "auto" && prefersDark.matches);
    document.querySelectorAll("[data-rin-portrait]").forEach((img) => {
      const lightSrc = img.getAttribute("data-light-src");
      const darkSrc = img.getAttribute("data-dark-src");
      if (!lightSrc || !darkSrc) return;
      const nextSrc = useDark ? darkSrc : lightSrc;
      if (img.getAttribute("src") !== nextSrc) {
        img.setAttribute("src", nextSrc);
      }
    });
  };

  applyRinPortrait();
  new MutationObserver(applyRinPortrait).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"]
  });
  prefersDark.addEventListener("change", applyRinPortrait);
</script>

<style>
  .rin-dialogue {
    margin-top: 1.7rem;
    padding: 0.5rem;
    border: 3px solid #22171a;
    background: linear-gradient(180deg, #f3dfb8 0%, #e7c78f 100%);
    box-shadow:
      0 0 0 3px #5c3b22,
      0 0 0 6px #d6ab65;
  }

  .rin-dialogue-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: start;
    position: relative;
    border: 2px solid #22171a;
    background: #faf1de;
    padding: 0.75rem 7.3rem 0.75rem 0.75rem;
  }

  .rin-portrait {
    width: 112px;
    position: absolute;
    right: 0.95rem;
    bottom: -0.45rem;
    z-index: 2;
    pointer-events: none;
  }

  .rin-portrait img {
    display: block;
    width: 100%;
    height: auto;
    image-rendering: pixelated;
    filter: drop-shadow(0 2px 0 rgba(24, 15, 12, 0.8));
  }

  .rin-copy {
    min-width: 0;
  }

  .rin-disclosure {
    margin: 0 0 0.3rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7a5533;
  }

  .rin-meta {
    margin: 0 0 0.45rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 0.7rem;
    align-items: baseline;
    font-size: 0.86rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .rin-meta strong {
    color: #462813;
  }

  .rin-meta span {
    color: #6e4429;
  }

  .rin-body {
    margin: 0;
    white-space: pre-line;
    line-height: 1.56;
    font-family: "Trebuchet MS", "Verdana", sans-serif;
    color: #2a1d13;
  }

  :global(:root[data-theme="dark"]) .rin-dialogue {
    border-color: #1a1214;
    background: linear-gradient(180deg, #33231f 0%, #241a18 100%);
    box-shadow:
      0 0 0 3px #0f0b0c,
      0 0 0 6px #62422c;
  }

  :global(:root[data-theme="dark"]) .rin-dialogue-shell {
    border-color: #a27c4e;
    background: #1a1413;
  }

  :global(:root[data-theme="dark"]) .rin-portrait {
    align-self: end;
  }

  :global(:root[data-theme="dark"]) .rin-portrait img {
    filter:
      drop-shadow(0 1px 0 rgba(0, 0, 0, 0.55))
      drop-shadow(0 0 8px rgba(177, 105, 48, 0.25));
  }

  :global(:root[data-theme="dark"]) .rin-disclosure {
    color: #be935f;
  }

  :global(:root[data-theme="dark"]) .rin-meta strong {
    color: #f2c998;
  }

  :global(:root[data-theme="dark"]) .rin-meta span {
    color: #d9b183;
  }

  :global(:root[data-theme="dark"]) .rin-body {
    color: #f4e6cf;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root[data-theme="auto"]) .rin-dialogue {
      border-color: #1a1214;
      background: linear-gradient(180deg, #33231f 0%, #241a18 100%);
      box-shadow:
        0 0 0 3px #0f0b0c,
        0 0 0 6px #62422c;
    }

    :global(:root[data-theme="auto"]) .rin-dialogue-shell {
      border-color: #a27c4e;
      background: #1a1413;
    }

    :global(:root[data-theme="auto"]) .rin-portrait {
      align-self: end;
    }

    :global(:root[data-theme="auto"]) .rin-portrait img {
      filter:
        drop-shadow(0 1px 0 rgba(0, 0, 0, 0.55))
        drop-shadow(0 0 8px rgba(177, 105, 48, 0.25));
    }

    :global(:root[data-theme="auto"]) .rin-disclosure {
      color: #be935f;
    }

    :global(:root[data-theme="auto"]) .rin-meta strong {
      color: #f2c998;
    }

    :global(:root[data-theme="auto"]) .rin-meta span {
      color: #d9b183;
    }

    :global(:root[data-theme="auto"]) .rin-body {
      color: #f4e6cf;
    }

  }

  @media (max-width: 560px) {
    .rin-dialogue-shell {
      grid-template-columns: 1fr;
      padding-right: 0.75rem;
    }

    .rin-portrait {
      width: 90px;
      position: static;
      margin-left: auto;
      margin-top: 0.35rem;
    }
  }
</style>
