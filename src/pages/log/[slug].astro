---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BeanEntry from "../../components/BeanEntry.astro";
import { getBeanRouteInfoMap, getBeans } from "../../data/beans";
import { withBase } from "../../utils/paths";

export async function getStaticPaths() {
  const beans = await getBeans();
  const beanRouteInfo = getBeanRouteInfoMap(beans);

  return beans.flatMap((bean, index) => {
    const info = beanRouteInfo.get(bean.slug);

    return (info?.aliases ?? [bean.slug]).map((slug) => ({
      params: { slug },
      props: {
        bean,
        beanRouteInfo: info,
        prev: index < beans.length - 1 ? beans[index + 1] : null,
        prevRouteInfo:
          index < beans.length - 1 ? beanRouteInfo.get(beans[index + 1].slug) ?? null : null,
        next: index > 0 ? beans[index - 1] : null,
        nextRouteInfo: index > 0 ? beanRouteInfo.get(beans[index - 1].slug) ?? null : null
      }
    }));
  });
}

const { bean, beanRouteInfo, prev, prevRouteInfo, next, nextRouteInfo } = Astro.props;
const initialCommand = `$ bean ${beanRouteInfo.commandText}`;
const initialLinkHref = withBase(beanRouteInfo.path);
---
<BaseLayout
  title={`${beanRouteInfo.titleLabel} · Beans`}
  description={bean.data.title}
  initialCommand={initialCommand}
  initialLinkHref={initialLinkHref}
>
  <section class="bean-detail">
    <BeanEntry bean={bean} routeInfo={beanRouteInfo} showBuddyComment={true} showClosingMark={true} />
    <nav class="bean-nav" aria-label="Bean log navigation">
      {prev ? (
        <a class="bean-nav-link" href={withBase(prevRouteInfo?.path ?? `/log/${prev.slug}/`)}>
          ← Prev: {prevRouteInfo?.displayLabel ?? prev.data.date}
        </a>
      ) : (
        <span class="bean-nav-muted">← Prev</span>
      )}
      {next ? (
        <a class="bean-nav-link" href={withBase(nextRouteInfo?.path ?? `/log/${next.slug}/`)}>
          Next: {nextRouteInfo?.displayLabel ?? next.data.date} →
        </a>
      ) : (
        <span class="bean-nav-muted">Next →</span>
      )}
    </nav>
    <p class="bean-back">
      <a href={withBase("/")}>Back to all beans</a>
    </p>
  </section>
</BaseLayout>
