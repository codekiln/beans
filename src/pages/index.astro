---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getHomeEntries } from "../data/homeEntries";
import { withBase } from "../utils/paths";

const entries = await getHomeEntries();
const initialCommand = "$ bean log list";
---
<BaseLayout
  title="Beans"
  description="A coffee log."
  initialCommand={initialCommand}
>
  <section class="hero">
    <h1 class="bean-prompt">
      <span class="bean-prompt-link">
        <span class="bean-prompt-time">
          <span class="bean-prompt-emoji" aria-hidden="true">🫘</span>
          <span aria-hidden="true">&gt;</span>
        </span>
        <span class="bean-prompt-command">bean log list</span>
      </span>
    </h1>
    <p>logs and questions</p>
    <nav class="home-nav" aria-label="Site sections">
      <a href={withBase("/about/")}>[about]</a>
      <span aria-hidden="true">·</span>
      <a href={withBase("/equipment/")}>[equipment]</a>
      <span aria-hidden="true">·</span>
      <a href={withBase("/recipes/")}>[recipes]</a>
      <span aria-hidden="true">·</span>
      <a href={withBase("/roasters/")}>[roasters]</a>
      <span aria-hidden="true">·</span>
      <a href={withBase("/coffees/")}>[coffees]</a>
      <span aria-hidden="true">·</span>
      <a href={withBase("/companion/")}>[companions]</a>
      <span aria-hidden="true">·</span>
      <a href={withBase("/questions/")}>[questions]</a>
      <span aria-hidden="true">·</span>
      <a href={withBase("/terms/")}>[terms]</a>
    </nav>
  </section>
  <section class="window" aria-label="Beans notebook logs and questions">
    <h2 class="section-title">Logs and Questions</h2>
    <ul class="table-list stream-list">
      {entries.map((entry) => (
        <li
          class:list={[
            "stream-entry",
            entry.kind === "question" && "stream-entry-question"
          ]}
          data-cli-log={entry.cliLog}
          data-cli-href={withBase(entry.href)}
        >
          {entry.kind === "bean" ? (
            <>
              <p class="stream-entry-command">
                <a href={withBase(entry.href)}>$ bean {entry.cliLog}</a>
              </p>
              <p class="stream-entry-title">
                <a href={withBase(entry.href)}>
                  [{entry.bean.data.date} {entry.bean.data.beanKey}]
                </a>
                {" "}· {entry.bean.data.title}
              </p>
            </>
          ) : (
            <>
              <p class="stream-entry-command">
                <a href={withBase(entry.href)}>$ bean {entry.cliLog}</a>
              </p>
              <p class="stream-entry-title">
                <a href={withBase(entry.href)}>[{entry.question.data.dateCreated} question]</a>
                {" "}· {entry.question.data.title}
              </p>
              <p class="stream-entry-summary">{entry.question.data.summary}</p>
            </>
          )}
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
