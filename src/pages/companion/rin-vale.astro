---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBeans } from "../../data/beans";
import { withBase } from "../../utils/paths";

const allBeans = await getBeans();
const rinBeans = allBeans.filter((bean) => bean.data.personaComment?.name === "Rin Vale");
const initialCommand = "$ beans companion rin-vale";
const initialLinkHref = withBase("/companion/rin-vale/");
---
<BaseLayout
  title="Rin Vale · Beans Companion"
  description="Campfire Cupping Companion"
  initialCommand={initialCommand}
  initialLinkHref={initialLinkHref}
>
  <section class="companion-page">
    <div class="window companion-hero">
      <p class="companion-kicker">COMPANION PROFILE</p>
      <h1>Rin Vale</h1>
      <p class="companion-title">Campfire Cupping Companion</p>
      <p>
        Rin reads like the friend who keeps a kettle near the cabin stove, notices where sweetness
        almost showed up, and answers with one practical adjustment instead of a lecture.
      </p>
      <p>
        The running voice is grounded, encouraging, and a little woodsmoke-coded: campfire,
        pines, mountain air, lake stillness, and a steady eye on how the next brew can land better.
      </p>
    </div>

    <div class="window companion-logbook">
      <h2>Commented Cups</h2>
      {rinBeans.length > 0 ? (
        <ul class="companion-links">
          {rinBeans.map((bean) => (
            <li>
              <a href={withBase(`/log/${bean.slug}/`)}>
                {bean.data.date} {bean.data.beanKey}
              </a>
              <span>{bean.data.title}</span>
            </li>
          ))}
        </ul>
      ) : (
        <p>No buddy comments logged yet.</p>
      )}
    </div>

    <p class="companion-back">
      <a href={withBase("/")}>Back to all beans</a>
    </p>
  </section>
</BaseLayout>

<style>
  .companion-page {
    display: grid;
    gap: 1.4rem;
  }

  .companion-hero,
  .companion-logbook {
    padding: 1rem 1.1rem;
  }

  .companion-kicker {
    margin: 0 0 0.45rem;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .companion-hero h1,
  .companion-logbook h2 {
    margin-top: 0;
  }

  .companion-title {
    margin-top: -0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent);
  }

  .companion-links {
    margin: 0;
    padding-left: 1.15rem;
  }

  .companion-links li + li {
    margin-top: 0.45rem;
  }

  .companion-links span {
    display: block;
    color: var(--muted);
  }

  .companion-back {
    margin: 0;
  }
</style>
