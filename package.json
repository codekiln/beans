{
  "name": "beans",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "dev-local": "astro dev --host 0.0.0.0 --port 4322",
    "dev-worktree": "astro dev --host 127.0.0.1",
    "check:markdown-a11y": "node dev/checks/markdown-a11y.mjs",
    "check:bean-rendering": "node dev/checks/bean-rendering.mjs",
    "check:rss-rendering": "node dev/checks/rss-rendering.mjs",
    "check:rss-reader-harness": "node dev/rss-reader-harness.mjs --check",
    "check:content-routes": "node dev/checks/content-routes.mjs",
    "check:beads-start": "bash dev/checks/beads-start-smoke.sh",
    "check:beads-finish": "bash dev/checks/beads-finish-smoke.sh",
    "check:beads-pre-push": "bash dev/checks/beads-pre-push-smoke.sh",
    "check:beads-prune-closed-worktrees": "bash dev/checks/beads-prune-closed-worktrees-smoke.sh",
    "check:land-the-plane": "bash dev/checks/land-the-plane-smoke.sh",
    "update:rss-reader-harness": "node dev/rss-reader-harness.mjs --write src/data/rss-reader-harness.json",
    "build": "astro build",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/rss": "^4.0.18",
    "astro": "^6.1.1"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "rulesync": "^7.23.0",
    "sury": "10.0.4"
  }
}
