#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: dev/beads-prune-closed-worktrees [--dry-run] [--force]

Removes Beads task worktrees under worktrees/beans-* when the corresponding
issue is closed in the Beads database.

Paths registered with Git are removed via git worktree remove. Directories
that still exist on disk for a closed issue but are not Git worktrees
(orphan fragments) are removed with rm -rf.

Options:
  --dry-run  Print the worktrees that would be removed without removing them
  --force    Pass --force to git worktree remove
USAGE
}

dry_run=false
force=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      dry_run=true
      shift
      ;;
    --force)
      force=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

repo_root="$(git rev-parse --show-toplevel)"
worktree_root="$repo_root/worktrees"
closed_ids_file="$(mktemp)"
registered_paths_file="$(mktemp)"
trap 'rm -f "$closed_ids_file" "$registered_paths_file"' EXIT

bd list --status closed | grep -oE 'beans-[a-z0-9.]+' | sort -u >"$closed_ids_file" || true

if [[ ! -s "$closed_ids_file" ]]; then
  echo "No closed Beads issues found."
  exit 0
fi

git worktree list --porcelain | awk '
  /^worktree / { print substr($0, 10) }
' >"$registered_paths_file"

git_candidates=()
while IFS= read -r path; do
  [[ -n "$path" ]] || continue
  case "$path" in
    "$worktree_root"/beans-*)
      issue_id="$(basename "$path")"
      if [[ "$issue_id" =~ ^beans-[a-z0-9.]+$ ]] && grep -Fxq "$issue_id" "$closed_ids_file"; then
        git_candidates+=("$path")
      fi
      ;;
  esac
done <"$registered_paths_file"

orphan_candidates=()
if [[ -d "$worktree_root" ]]; then
  shopt -s nullglob
  for path in "$worktree_root"/beans-*; do
    [[ -d "$path" ]] || continue
    issue_id="$(basename "$path")"
    if [[ ! "$issue_id" =~ ^beans-[a-z0-9.]+$ ]]; then
      continue
    fi
    if ! grep -Fxq "$issue_id" "$closed_ids_file"; then
      continue
    fi
    if ! grep -Fxq "$path" "$registered_paths_file"; then
      orphan_candidates+=("$path")
    fi
  done
  shopt -u nullglob
fi

total=$((${#git_candidates[@]} + ${#orphan_candidates[@]}))

if [[ "$total" -eq 0 ]]; then
  echo "No closed-task Beads worktrees to remove."
  exit 0
fi

if [[ "${#git_candidates[@]}" -gt 0 ]]; then
  echo "Closed-task git worktrees:"
  printf '%s\n' "${git_candidates[@]}"
fi

if [[ "${#orphan_candidates[@]}" -gt 0 ]]; then
  echo "Closed-task orphan directories (not registered as git worktrees):"
  printf '%s\n' "${orphan_candidates[@]}"
fi

if [[ "$dry_run" == true ]]; then
  echo "Dry run only; no worktrees removed."
  exit 0
fi

remove_args=(worktree remove)
if [[ "$force" == true ]]; then
  remove_args+=(--force)
fi

for path in "${git_candidates[@]}"; do
  git "${remove_args[@]}" "$path"
done

for path in "${orphan_candidates[@]}"; do
  rm -rf "$path"
done

git worktree prune

echo "Removed $total closed-task worktree(s)."
