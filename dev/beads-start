#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: dev/beads-start <issue-id> [branch]

Starts Beads work quickly:
  1) Claim issue
  2) Warn if the source checkout is dirty
  2) Ensure worktree at worktrees/<issue-id>
  3) Ensure branch (default: codex/<issue-id>)
USAGE
}

issue_id="${1:-}"
branch="${2:-}"

if [[ -z "$issue_id" ]]; then
  usage
  exit 1
fi

if [[ -z "$branch" ]]; then
  branch="codex/$issue_id"
fi

worktree_path="worktrees/$issue_id"
gitignore_path=".gitignore"
worktree_beads_path="$worktree_path/.beads"
worktree_redirect_path="$worktree_beads_path/redirect"
repo_beads_redirect="../../.beads"
git_common_dir="$(git rev-parse --git-common-dir)"
hooks_dir="$git_common_dir/hooks"
repo_root="$(git rev-parse --show-toplevel)"
repo_pre_push_hook="$repo_root/dev/hooks/pre-push"
pre_push_hook_path="$hooks_dir/pre-push"

bd_cmd() {
  bd "$@"
}

push_beads_dolt() {
  local dolt_password="${DOLT_REMOTE_PASSWORD:-}"

  if [[ -z "$dolt_password" ]]; then
    if ! command -v gh >/dev/null 2>&1; then
      echo "Beads mutation needs a Dolt push, but gh is not available to mint a token." >&2
      exit 1
    fi

    dolt_password="$(gh auth token)"
  fi

  DOLT_REMOTE_PASSWORD="$dolt_password" bd dolt push >/dev/null
}

refresh_bd_hooks() {
  bd hooks install --force >/dev/null
}

install_repo_pre_push_hook() {
  mkdir -p "$hooks_dir"

  cat >"$pre_push_hook_path" <<EOF
#!/bin/sh
set -eu

repo_hook="$repo_pre_push_hook"
tmp_file="\$(mktemp)"
trap 'rm -f "\$tmp_file"' EXIT HUP INT TERM
cat >"\$tmp_file"

if command -v bd >/dev/null 2>&1; then
  bd hooks run pre-push "\$@" <"\$tmp_file"
fi

if [ -x "\$repo_hook" ]; then
  exec "\$repo_hook" "\$@" <"\$tmp_file"
fi

exit 0
EOF

  chmod +x "$pre_push_hook_path"
}

cleanup_gitignore_entry() {
  local entry="$1"
  local tmp_file

  [[ -f "$gitignore_path" ]] || return 0
  if ! grep -Fqx "$entry" "$gitignore_path" &&
    ! grep -Fqx "# bd worktree" "$gitignore_path"; then
    return 0
  fi

  tmp_file="$(mktemp)"
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "$entry" || "$line" == "# bd worktree" ]]; then
      continue
    fi

    printf '%s\n' "$line" >>"$tmp_file"
  done <"$gitignore_path"
  mv "$tmp_file" "$gitignore_path"
}

repair_beads_redirect() {
  mkdir -p "$worktree_beads_path"
  printf "%s\n" "$repo_beads_redirect" >"$worktree_redirect_path"
}

warn_if_checkout_dirty() {
  if [[ -n "$(git status --short)" ]]; then
    echo "Warning: source checkout has local changes before worktree startup." >&2
    git status --short
  fi
}

ensure_issue_is_claimed() {
  if bd_cmd update "$issue_id" --claim >/dev/null 2>&1; then
    push_beads_dolt
    return 0
  fi

  bd_cmd update "$issue_id" --status in_progress >/dev/null
  push_beads_dolt
}

bd_cmd prime >/dev/null || true
bd_cmd show "$issue_id" >/dev/null
refresh_bd_hooks
install_repo_pre_push_hook

warn_if_checkout_dirty
ensure_issue_is_claimed

if [[ -d "$worktree_path" ]]; then
  echo "Worktree exists: $worktree_path"
else
  bd_cmd worktree create "$worktree_path" --branch "$branch"
  cleanup_gitignore_entry "$worktree_path/"
fi

repair_beads_redirect

echo "Issue: $issue_id"
echo "Branch: $branch"
echo "Worktree: $worktree_path"
echo "Next: cd $worktree_path"
