#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: dev/beads-start <issue-id> [branch]

Starts Beads work quickly:
  1) Claim issue
  2) Warn if the source checkout is dirty
  2) Ensure worktree at worktrees/<issue-id>
  3) Ensure branch (default: codex/<issue-id>)
USAGE
}

issue_id="${1:-}"
branch="${2:-}"

if [[ -z "$issue_id" ]]; then
  usage
  exit 1
fi

if [[ -z "$branch" ]]; then
  branch="codex/$issue_id"
fi

worktree_path="worktrees/$issue_id"
gitignore_path=".gitignore"

cleanup_gitignore_entry() {
  local entry="$1"
  local tmp_file

  [[ -f "$gitignore_path" ]] || return 0
  grep -Fqx "$entry" "$gitignore_path" || return 0

  tmp_file="$(mktemp)"
  grep -Fvx "$entry" "$gitignore_path" >"$tmp_file" || true
  mv "$tmp_file" "$gitignore_path"
}

warn_if_checkout_dirty() {
  if [[ -n "$(git status --short)" ]]; then
    echo "Warning: source checkout has local changes before worktree startup." >&2
    git status --short
  fi
}

ensure_branch_exists() {
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    return 0
  fi

  git branch "$branch" HEAD >/dev/null
}

ensure_issue_is_claimed() {
  if ! bd update "$issue_id" --claim >/dev/null 2>&1; then
    bd update "$issue_id" --status in_progress >/dev/null
  fi
}

bd prime >/dev/null || true
bd show "$issue_id" >/dev/null

warn_if_checkout_dirty
ensure_issue_is_claimed
ensure_branch_exists

if [[ -d "$worktree_path" ]]; then
  echo "Worktree exists: $worktree_path"
else
  bd worktree create "$worktree_path" --branch "$branch"
  cleanup_gitignore_entry "$worktree_path/"
fi

echo "Issue: $issue_id"
echo "Branch: $branch"
echo "Worktree: $worktree_path"
echo "Next: cd $worktree_path"
