#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: dev/beads-finish <issue-id> [notes]

Wraps the common Beads finish sequence:
  1) Show issue details
  2) Optionally append notes while closing the issue
  3) Push the Beads mutation through the Dolt remote
  4) Show git status
USAGE
}

issue_id="${1:-}"
notes="${2:-}"

if [[ -z "$issue_id" ]]; then
  usage
  exit 1
fi

bd_cmd() {
  bd "$@"
}

push_beads_dolt() {
  local dolt_password="${DOLT_REMOTE_PASSWORD:-}"

  if [[ -z "$dolt_password" ]]; then
    if ! command -v gh >/dev/null 2>&1; then
      echo "Beads mutation needs a Dolt push, but gh is not available to mint a token." >&2
      exit 1
    fi

    dolt_password="$(gh auth token)"
  fi

  DOLT_REMOTE_PASSWORD="$dolt_password" bd dolt push >/dev/null
}

bd_cmd show "$issue_id"

if [[ -n "$notes" ]]; then
  bd_cmd update "$issue_id" --notes "$notes" --status closed >/dev/null
else
  bd_cmd update "$issue_id" --status closed >/dev/null
fi

push_beads_dolt
git status --short
bd_cmd show "$issue_id" --json

echo "Issue: $issue_id"
echo "Current branch: $(git rev-parse --abbrev-ref HEAD)"
echo "Beads metadata pushed through Dolt."
