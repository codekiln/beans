#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: dev/land-the-plane <issue-id> [notes] [options]

Runs the Beans session closeout ritual:
  1) Run default quality checks unless overridden
  2) File requested follow-up Beads issues, otherwise assume none
  3) Finish and sync the issue through dev/beads-finish
  4) Update local main from origin/main, merge the task branch into main, and push main
  5) Show final cleanup state and emit a next-session prompt

Options:
  --check "<command>"   Run this validation command before closeout
  --no-checks           Skip default validation commands for this landing
  --follow-up "<title>" Create a follow-up Beads issue before closing out
  --no-follow-up        Keep compatibility with old explicit-no-follow-up usage
  --require-checks      Fail unless explicit check commands are provided
  --require-follow-up   Fail unless explicit follow-up titles are provided
USAGE
}

issue_id="${1:-}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
notes=""
checks=()
follow_ups=()
no_checks=false
no_follow_up=false
require_checks=false
require_follow_up=false

if [[ -z "$issue_id" ]]; then
  usage
  exit 1
fi

shift

if [[ "${1:-}" != "" && "${1:-}" != --* ]]; then
  notes="$1"
  shift
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --check)
      checks+=("${2:-}")
      shift 2
      ;;
    --no-checks)
      no_checks=true
      shift
      ;;
    --follow-up)
      follow_ups+=("${2:-}")
      shift 2
      ;;
    --no-follow-up)
      no_follow_up=true
      shift
      ;;
    --require-checks)
      require_checks=true
      shift
      ;;
    --require-follow-up)
      require_follow_up=true
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

bd_cmd() {
  bd --no-daemon "$@"
}

print_section() {
  printf "\n%s\n" "$1"
}

print_or_none() {
  local output="$1"

  if [[ -n "$output" ]]; then
    printf "%s\n" "$output"
  else
    echo "(none)"
  fi
}

require_value() {
  local flag_name="$1"
  local flag_value="$2"

  if [[ -z "$flag_value" ]]; then
    echo "$flag_name requires a value" >&2
    exit 1
  fi
}

run_checks() {
  local check_cmd
  local default_checks=()

  if [[ "${#checks[@]}" -gt 0 && "$no_checks" == true ]]; then
    echo "Use either --check or --no-checks, not both" >&2
    exit 1
  fi

  if [[ "${#checks[@]}" -eq 0 && "$no_checks" == false ]]; then
    if [[ -f package.json ]] && grep -q '"check:beads-start"' package.json; then
      default_checks+=("npm run check:beads-start")
    fi

    if [[ -f package.json ]] && grep -q '"build"' package.json; then
      default_checks+=("npm run build")
    fi
  fi

  if [[ "${#checks[@]}" -eq 0 && "${#default_checks[@]}" -gt 0 ]]; then
    checks=("${default_checks[@]}")
  fi

  print_section "Quality gates:"

  if [[ "${#checks[@]}" -eq 0 ]]; then
    if [[ "$require_checks" == true ]]; then
      echo "Explicit check commands are required for this landing." >&2
      exit 1
    fi

    if [[ "$no_checks" == true ]]; then
      echo "Skipping validation commands for this landing."
    else
      echo "No default validation commands configured for this repo."
    fi
    return
  fi

  for check_cmd in "${checks[@]}"; do
    require_value "--check" "$check_cmd"
    echo "+ $check_cmd"
    eval "$check_cmd"
  done
}

create_follow_ups() {
  local title

  print_section "Follow-up issues:"

  if [[ "${#follow_ups[@]}" -eq 0 ]]; then
    if [[ "$require_follow_up" == true ]]; then
      echo "At least one explicit follow-up title is required for this landing." >&2
      exit 1
    fi

    if [[ "$no_follow_up" == true ]]; then
      echo "No follow-up issues created."
      return
    fi

    echo "No follow-up issues created."
    return
  fi

  for title in "${follow_ups[@]}"; do
    require_value "--follow-up" "$title"
    bd_cmd create "$title"
  done
}

find_main_worktree() {
  git worktree list --porcelain | awk '
    /^worktree / { path = substr($0, 10) }
    /^branch refs\/heads\/main$/ { print path; exit }
  '
}

ensure_worktree_clean() {
  local path="$1"
  local label="$2"
  local status_branch

  status_branch="$(git -C "$path" status --short)"

  if [[ -n "$status_branch" ]]; then
    echo "$label worktree is not clean: $path" >&2
    printf "%s\n" "$status_branch" >&2
    exit 1
  fi
}

land_on_main() {
  local branch
  local main_worktree

  branch="$(git rev-parse --abbrev-ref HEAD)"
  main_worktree="$(find_main_worktree)"

  if [[ -z "$main_worktree" ]]; then
    echo "Could not locate the main worktree. Make sure branch 'main' is checked out in one worktree." >&2
    exit 1
  fi

  if [[ "$branch" == "main" ]]; then
    echo "dev/land-the-plane should be run from the task worktree, not from main." >&2
    exit 1
  fi

  print_section "Landing on main:"

  bd_cmd sync --check
  bd_cmd sync --force

  ensure_worktree_clean "$main_worktree" "Main"

  git -C "$main_worktree" fetch origin
  git -C "$main_worktree" pull --ff-only origin main
  git -C "$main_worktree" merge --no-edit "$branch"
  git -C "$main_worktree" push origin main
}

verify_main_is_synced() {
  local main_worktree
  local status_branch

  main_worktree="$(find_main_worktree)"

  if [[ -z "$main_worktree" ]]; then
    echo "Could not locate the main worktree to verify sync status." >&2
    exit 1
  fi

  status_branch="$(git -C "$main_worktree" status --short --branch | head -n 1)"

  if [[ "$status_branch" == *"ahead "* || "$status_branch" == *"behind "* || "$status_branch" == *"[gone]"* ]]; then
    echo "Main is not fully synced with origin: $status_branch" >&2
    exit 1
  fi
}

run_checks
create_follow_ups
"$script_dir/beads-finish" "$issue_id" "$notes"
land_on_main
verify_main_is_synced

print_section "Final working tree review:"
git status --short --branch

main_worktree="$(find_main_worktree)"
if [[ -n "$main_worktree" ]]; then
  print_section "Main worktree review:"
  git -C "$main_worktree" status --short --branch
fi

print_section "Untracked files to review before leaving:"
untracked_files="$(git ls-files --others --exclude-standard || true)"
print_or_none "$untracked_files"

print_section "Git stashes to review before leaving:"
stash_list="$(git stash list || true)"
print_or_none "$stash_list"

print_section "Ready Beads work:"
ready_output="$(bd_cmd ready || true)"
print_or_none "$ready_output"

next_issue="$(printf "%s\n" "$ready_output" | grep -oE 'beans-[a-z0-9]+' | head -n 1 || true)"

if [[ -n "$next_issue" ]]; then
  print_section "Suggested next-session prompt:"
  cat <<EOF
Start with dev/beads-start $next_issue, read the issue with bd --no-daemon show $next_issue, confirm the worktree is clean, implement the task, then run dev/land-the-plane $next_issue before handing off.
EOF
fi
