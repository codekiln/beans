#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: dev/land-the-plane <issue-id> [notes] [options]

Runs the Beans session closeout ritual:
  1) Run default quality checks unless overridden
  2) File requested follow-up Beads issues, otherwise assume none
  3) Auto-commit tracked task-worktree edits when safe, or fail on ambiguity
  4) Finish and sync the issue through dev/beads-finish
  5) Update root main from origin/main, merge the task branch into main, and push main
  6) Assert final cleanup state and emit a next-session prompt

Options:
  --check "<command>"   Run this validation command before closeout
  --no-checks           Skip default validation commands for this landing
  --follow-up "<title>" Create a follow-up Beads issue before closing out
  --no-follow-up        Keep compatibility with old explicit-no-follow-up usage
  --require-checks      Fail unless explicit check commands are provided
  --require-follow-up   Fail unless explicit follow-up titles are provided
USAGE
}

issue_id="${1:-}"
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
notes=""
checks=()
follow_ups=()
no_checks=false
no_follow_up=false
require_checks=false
require_follow_up=false
current_worktree="$(git rev-parse --show-toplevel)"
current_branch="$(git rev-parse --abbrev-ref HEAD)"
git_common_dir="$(git rev-parse --path-format=absolute --git-common-dir)"
repo_root="$(cd "$git_common_dir/.." && pwd)"
beads_sync_worktree="$git_common_dir/beads-worktrees/beads-sync"

if [[ -z "$issue_id" ]]; then
  usage
  exit 1
fi

shift

if [[ "${1:-}" != "" && "${1:-}" != --* ]]; then
  notes="$1"
  shift
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --check)
      checks+=("${2:-}")
      shift 2
      ;;
    --no-checks)
      no_checks=true
      shift
      ;;
    --follow-up)
      follow_ups+=("${2:-}")
      shift 2
      ;;
    --no-follow-up)
      no_follow_up=true
      shift
      ;;
    --require-checks)
      require_checks=true
      shift
      ;;
    --require-follow-up)
      require_follow_up=true
      shift
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

bd_cmd() {
  bd --no-daemon "$@"
}

print_section() {
  printf "\n%s\n" "$1"
}

print_or_none() {
  local output="$1"

  if [[ -n "$output" ]]; then
    printf "%s\n" "$output"
  else
    echo "(none)"
  fi
}

require_value() {
  local flag_name="$1"
  local flag_value="$2"

  if [[ -z "$flag_value" ]]; then
    echo "$flag_name requires a value" >&2
    exit 1
  fi
}

ensure_not_running_from_main() {
  if [[ "$current_branch" == "main" ]]; then
    echo "dev/land-the-plane should be run from a task worktree, not from main." >&2
    exit 1
  fi
}

ensure_root_main_policy() {
  local root_branch

  root_branch="$(git -C "$repo_root" rev-parse --abbrev-ref HEAD)"

  if [[ "$root_branch" != "main" ]]; then
    echo "Repo root checkout must stay on main for integration-only landings. Current root branch: $root_branch" >&2
    exit 1
  fi
}

ensure_root_main_clean_before_closeout() {
  ensure_worktree_clean "$repo_root" "Root main"
}

ensure_worktree_clean() {
  local path="$1"
  local label="$2"
  local status_output

  status_output="$(git -C "$path" status --short)"

  if [[ -n "$status_output" ]]; then
    echo "$label worktree is not clean: $path" >&2
    printf "%s\n" "$status_output" >&2
    exit 1
  fi
}

ensure_branch_is_synced() {
  local path="$1"
  local label="$2"
  local status_branch

  status_branch="$(git -C "$path" status --short --branch | head -n 1)"

  if [[ "$status_branch" == *"ahead "* || "$status_branch" == *"behind "* || "$status_branch" == *"[gone]"* ]]; then
    echo "$label is not fully synced with origin: $status_branch" >&2
    exit 1
  fi
}

run_checks() {
  local check_cmd
  local default_checks=()

  if [[ "${#checks[@]}" -gt 0 && "$no_checks" == true ]]; then
    echo "Use either --check or --no-checks, not both" >&2
    exit 1
  fi

  if [[ "${#checks[@]}" -eq 0 && "$no_checks" == false ]]; then
    if [[ -f package.json ]] && grep -q '"check:beads-start"' package.json; then
      default_checks+=("npm run check:beads-start")
    fi

    if [[ -f package.json ]] && grep -q '"build"' package.json; then
      default_checks+=("npm run build")
    fi
  fi

  if [[ "${#checks[@]}" -eq 0 && "${#default_checks[@]}" -gt 0 ]]; then
    checks=("${default_checks[@]}")
  fi

  print_section "Quality gates:"

  if [[ "${#checks[@]}" -eq 0 ]]; then
    if [[ "$require_checks" == true ]]; then
      echo "Explicit check commands are required for this landing." >&2
      exit 1
    fi

    if [[ "$no_checks" == true ]]; then
      echo "Skipping validation commands for this landing."
    else
      echo "No default validation commands configured for this repo."
    fi
    return
  fi

  for check_cmd in "${checks[@]}"; do
    require_value "--check" "$check_cmd"
    echo "+ $check_cmd"
    eval "$check_cmd"
  done
}

create_follow_ups() {
  local title

  print_section "Follow-up issues:"

  if [[ "${#follow_ups[@]}" -eq 0 ]]; then
    if [[ "$require_follow_up" == true ]]; then
      echo "At least one explicit follow-up title is required for this landing." >&2
      exit 1
    fi

    echo "No follow-up issues created."
    return
  fi

  for title in "${follow_ups[@]}"; do
    require_value "--follow-up" "$title"
    bd_cmd create "$title"
  done
}

auto_commit_task_worktree_if_safe() {
  local status_output
  local pre_commit_head
  local post_commit_head
  local post_commit_status

  status_output="$(git status --porcelain)"

  if [[ -z "$status_output" ]]; then
    return
  fi

  if printf "%s\n" "$status_output" | grep -qE '^(AA|AU|DD|DU|UA|UD|UU) '; then
    echo "Task worktree has unresolved merge state. Resolve it before landing:" >&2
    printf "%s\n" "$status_output" >&2
    exit 1
  fi

  print_section "Task worktree checkpoint:"
  printf "%s\n" "$status_output"
  pre_commit_head="$(git rev-parse HEAD)"
  git add -A
  git commit -m "chore(land-the-plane): checkpoint $issue_id"

  post_commit_head="$(git rev-parse HEAD)"
  post_commit_status="$(git status --porcelain)"

  if [[ "$post_commit_head" == "$pre_commit_head" ]]; then
    echo "Task worktree checkpoint did not create a new commit. Refusing to close out with uncheckpointed task changes." >&2
    exit 1
  fi

  if [[ -n "$post_commit_status" ]]; then
    echo "Task worktree is still dirty after checkpoint commit. Refusing to close out:" >&2
    printf "%s\n" "$post_commit_status" >&2
    exit 1
  fi
}

cleanup_root_main_metadata_mirror() {
  local metadata_path=".beads/issues.jsonl"
  local metadata_status

  metadata_status="$(git -C "$repo_root" status --short -- "$metadata_path")"

  if [[ -z "$metadata_status" ]]; then
    return
  fi

  print_section "Cleaning root main metadata mirror:"
  printf "%s\n" "$metadata_status"
  git -C "$repo_root" restore --staged --worktree -- "$metadata_path"
}

land_on_root_main() {
  local merge_conflicts

  print_section "Landing on root main:"

  ensure_worktree_clean "$repo_root" "Root main"

  git -C "$repo_root" fetch origin
  git -C "$repo_root" pull --ff-only origin main

  if ! git -C "$repo_root" merge --no-edit "$current_branch"; then
    merge_conflicts="$(git -C "$repo_root" diff --name-only --diff-filter=U || true)"

    if [[ -n "$merge_conflicts" ]]; then
      echo "Root main merge conflict while landing $current_branch into main. Resolve these files in $repo_root before continuing:" >&2
      printf "%s\n" "$merge_conflicts" >&2
    else
      echo "Failed to merge $current_branch into root main at $repo_root." >&2
    fi

    exit 1
  fi

}

sync_beads_metadata_branch() {
  local sync_status
  local sync_branch_status

  if [[ ! -d "$beads_sync_worktree" ]]; then
    echo "Could not locate the beads-sync worktree at $beads_sync_worktree" >&2
    exit 1
  fi

  sync_status="$(git -C "$beads_sync_worktree" status --short)"
  sync_branch_status="$(git -C "$beads_sync_worktree" status --short --branch | head -n 1)"

  if [[ -z "$sync_status" && "$sync_branch_status" != *"ahead "* ]]; then
    return
  fi

  print_section "Syncing beads-sync:"
  printf "%s\n" "$sync_branch_status"
  if [[ -n "$sync_status" ]]; then
    printf "%s\n" "$sync_status"
    git -C "$beads_sync_worktree" add .beads/issues.jsonl
    git -C "$beads_sync_worktree" commit -m "chore(beads): sync $issue_id metadata"
  fi
  git -C "$beads_sync_worktree" push origin beads-sync
}

prune_closed_task_worktrees() {
  print_section "Pruning closed task worktrees:"

  cd "$repo_root"
  "$script_dir/beads-prune-closed-worktrees"

  if [[ -e "$current_worktree" ]]; then
    echo "Closed task worktree still exists after prune: $current_worktree" >&2
    exit 1
  fi
}

assert_task_commit_landed() {
  local task_head="$1"

  if ! git -C "$repo_root" merge-base --is-ancestor "$task_head" HEAD; then
    echo "Task branch HEAD was not merged into root main: $task_head" >&2
    exit 1
  fi
}

select_next_issue() {
  local ready_output="$1"
  local candidates
  local candidate_id
  local ready_index=0
  local details
  local priority=9
  local type_name=""
  local type_rank=1
  local score_file

  candidates="$(printf "%s\n" "$ready_output" | grep -oE 'beans-[a-z0-9.]+' | awk '!seen[$0]++' || true)"

  if [[ -z "$candidates" ]]; then
    return
  fi

  score_file="$(mktemp)"

  while IFS= read -r candidate_id; do
    [[ -n "$candidate_id" ]] || continue
    details="$(bd_cmd show "$candidate_id" 2>/dev/null || true)"
    priority="$(printf "%s\n" "$details" | grep -oE 'P[0-4]' | head -n 1 | tr -d 'P' || true)"
    type_name="$(
      printf "%s\n" "$details" |
        grep -oE 'Type: [A-Za-z]+' |
        head -n 1 |
        awk '{ print tolower($2) }'
    )"

    if [[ -z "$priority" ]]; then
      priority=9
    fi

    case "$type_name" in
      task|bug)
        type_rank=0
        ;;
      epic)
        type_rank=2
        ;;
      *)
        type_rank=1
        ;;
    esac

    printf "%s\t%s\t%s\t%s\n" "$type_rank" "$priority" "$ready_index" "$candidate_id" >>"$score_file"
    ready_index=$((ready_index + 1))
  done <<<"$candidates"

  sort -t $'\t' -k1,1n -k2,2n -k3,3n "$score_file" | head -n 1 | cut -f4
  rm -f "$score_file"
}

print_final_state() {
  local task_head="$1"
  local main_head
  local beads_sync_head

  if [[ -e "$current_worktree" ]]; then
    echo "Closed task worktree should have been pruned during closeout: $current_worktree" >&2
    exit 1
  fi

  ensure_worktree_clean "$repo_root" "Root main"
  ensure_branch_is_synced "$repo_root" "Root main"

  if [[ ! -d "$beads_sync_worktree" ]]; then
    echo "Could not locate the beads-sync worktree at $beads_sync_worktree" >&2
    exit 1
  fi

  ensure_worktree_clean "$beads_sync_worktree" "beads-sync"
  ensure_branch_is_synced "$beads_sync_worktree" "beads-sync"
  assert_task_commit_landed "$task_head"

  main_head="$(git -C "$repo_root" rev-parse HEAD)"
  beads_sync_head="$(git -C "$beads_sync_worktree" rev-parse HEAD)"

  print_section "Final landed state:"
  echo "Task branch: $current_branch @ $task_head"
  echo "Task worktree pruned: $current_worktree"
  echo "Root main: $main_head"
  echo "beads-sync: $beads_sync_head"
}

ensure_not_running_from_main
ensure_root_main_policy
ensure_root_main_clean_before_closeout
run_checks
create_follow_ups
auto_commit_task_worktree_if_safe
task_head="$(git rev-parse HEAD)"
"$script_dir/beads-finish" "$issue_id" "$notes"
cleanup_root_main_metadata_mirror
land_on_root_main
sync_beads_metadata_branch
git -C "$repo_root" push origin main

print_section "Task worktree review:"
git status --short --branch

print_section "Root main review:"
git -C "$repo_root" status --short --branch

prune_closed_task_worktrees
print_final_state "$task_head"

print_section "Untracked files to review before leaving:"
untracked_files="$(git ls-files --others --exclude-standard || true)"
print_or_none "$untracked_files"

print_section "Git stashes to review before leaving:"
stash_list="$(git stash list || true)"
print_or_none "$stash_list"

print_section "Ready Beads work:"
ready_output="$(bd_cmd ready || true)"
print_or_none "$ready_output"

next_issue="$(select_next_issue "$ready_output")"

if [[ -n "$next_issue" ]]; then
  print_section "Suggested next-session prompt:"
  echo "Heuristic: prefer ready task/bug work, then lower P-number, then existing ready order."
  cat <<EOF
Start with dev/beads-start $next_issue, read the issue with bd --no-daemon show $next_issue, confirm the worktree is clean, implement the task, then run dev/land-the-plane $next_issue before handing off.
EOF
fi
